# Install all dependencies
install:
	uv sync

# Run the FastAPI server in dev mode
run:
	uv run uvicorn app.main:app --reload

# Run unit tests
test:
	uv run pytest

# Lint check with ruff
lint:
	uv run ruff check .

# Format code with ruff
format:
	uv run ruff format .

# Type check with mypy
typecheck:
	uv run mypy .
